{
  "name": "maverick",
  "version": "2.0.5",
  "description": "Maverick CLI - Command line interface for the Maverick social media scheduling API",
  "main": "dist/index.js",
  "bin": {
    "maverick": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "start": "node ./dist/index.js",
    "publish": "tsup && pnpm publish --access public --no-git-checks"
  },
  "files": [
    "dist",
    "README.md",
    "SKILL.md"
  ],
  "keywords": [
    "maverick",
    "cli",
    "social media",
    "scheduling",
    "automation",
    "ai-agent",
    "command-line"
  ],
  "author": "Mav Contributors",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/maboroshi-inc/mav.git",
    "directory": "apps/cli"
  },
  "homepage": "https://maverick.com",
  "bugs": {
    "url": "https://github.com/maboroshi-inc/mav/issues"
  },
  "devDependencies": {
    "boxen": "^8.0.1",
    "chalk": "5",
    "cli-table3": "^0.6.5",
    "figures": "^6.1.0",
    "ora": "^8.2.0"
  }
}
